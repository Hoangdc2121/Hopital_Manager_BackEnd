generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  MEDICAL_STAFF
  PATIENT
}

enum Gender {
  MALE
  FEMALE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentMethod {
  CASH
  VNPAY
}

enum InvoiceItemType {
  SERVICE
  MEDICINE
  LAB_TEST
}

enum AppointmentRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCEL
}

model User {
  id Int @id @default(autoincrement())

  fullName String
  email    String  @unique
  password String
  avatar   String?

  gender      Gender?
  dateOfBirth DateTime?
  phoneNumber String?
  address     String?

  role Role

  isActive Boolean @default(true)

  departmentId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department Department? @relation(fields: [departmentId], references: [id])

  doctorAppointments  Appointment[] @relation("DoctorAppointments")
  patientAppointments Appointment[] @relation("PatientAppointments")

  doctorMedicalRecords  MedicalRecord[] @relation("DoctorMedicalRecords")
  patientMedicalRecords MedicalRecord[] @relation("PatientMedicalRecords")

  payments         Payment[]
  notifications    Notification[]
  doctorSchedules  DoctorSchedule[]
  vitalSigns       VitalSign[]
  sentRequests     AppointmentRequest[] @relation("PatientRequest")
  reviewedRequests AppointmentRequest[] @relation("StaffReview")
}

model Department {
  id   Int    @id @default(autoincrement())
  code String @unique
  name String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  appointments Appointment[]
}

model DoctorSchedule {
  id Int @id @default(autoincrement())

  doctorId Int

  dayOfWeek Int
  startTime Int
  endTime   Int

  slotDuration Int
  isActive Boolean @default(true)

  doctor User @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
}

model Appointment {
  id Int @id @default(autoincrement())

  code String @unique

  patientId    Int
  doctorId     Int
  departmentId Int

  appointmentDate DateTime

  reason String?

  status AppointmentStatus @default(PENDING)

  checkedInById Int?
  checkedInAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient User @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor  User @relation("DoctorAppointments", fields: [doctorId], references: [id])

  department Department @relation(fields: [departmentId], references: [id])

  vitalSigns          VitalSign[]
  medicalRecord       MedicalRecord?
  invoice             Invoice?
  appointmentRequests AppointmentRequest[]
}

model VitalSign {
  id Int @id @default(autoincrement())

  appointmentId Int
  recordedById  Int

  bloodPressure   String?
  heartRate       Int?
  temperature     Float?
  spo2            Int?
  respiratoryRate Int?

  height Float?
  weight Float?

  note String?

  createdAt DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  recordedBy  User        @relation(fields: [recordedById], references: [id])
}

model MedicalRecord {
  id Int @id @default(autoincrement())

  appointmentId Int @unique
  doctorId      Int
  patientId     Int

  symptoms   String?
  diagnosis  String?
  conclusion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  doctor  User @relation("DoctorMedicalRecords", fields: [doctorId], references: [id])
  patient User @relation("PatientMedicalRecords", fields: [patientId], references: [id])

  labOrders     LabOrder[]
  prescriptions Prescription[]
}

model LabOrder {
  id Int @id @default(autoincrement())

  medicalRecordId Int

  testName String
  note     String?

  createdAt DateTime @default(now())

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id])

  results LabResult[]
}

model LabResult {
  id Int @id @default(autoincrement())

  labOrderId Int

  resultText String?
  fileUrl    String?

  createdAt DateTime @default(now())

  labOrder LabOrder @relation(fields: [labOrderId], references: [id])
}

model Medicine {
  id Int @id @default(autoincrement())

  name  String
  unit  String
  price Float
  stock Int

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prescriptionItems PrescriptionItem[]
}

model Prescription {
  id Int @id @default(autoincrement())

  medicalRecordId Int

  createdAt DateTime @default(now())

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id])

  items PrescriptionItem[]
}

model PrescriptionItem {
  id Int @id @default(autoincrement())

  prescriptionId Int
  medicineId     Int

  dosage   String
  days     Int
  quantity Int
  price    Float

  prescription Prescription @relation(fields: [prescriptionId], references: [id])
  medicine     Medicine     @relation(fields: [medicineId], references: [id])
}

model Invoice {
  id Int @id @default(autoincrement())

  appointmentId Int @unique

  totalAmount Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  items    InvoiceItem[]
  payments Payment[]
}

model InvoiceItem {
  id Int @id @default(autoincrement())

  invoiceId Int

  type InvoiceItemType

  name String

  price    Float
  quantity Int

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Payment {
  id Int @id @default(autoincrement())

  invoiceId Int
  userId    Int

  amount Float

  method PaymentMethod
  status PaymentStatus @default(PENDING)

  vnpayTxnRef        String?
  vnpayTransactionNo String?
  vnpayResponseCode  String?

  paidAt DateTime?

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Notification {
  id Int @id @default(autoincrement())

  userId Int

  title   String
  content String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AppointmentRequest {
  id Int @id @default(autoincrement())

  appointmentId Int
  patientId     Int

  status AppointmentRequestStatus @default(PENDING)

  newDoctorId  Int?
  newDate      DateTime?
  newSlotStart Int?
  newSlotEnd   Int?

  note String?

  reviewedById Int?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  patient     User        @relation("PatientRequest", fields: [patientId], references: [id])
  reviewedBy  User?       @relation("StaffReview", fields: [reviewedById], references: [id])
}
